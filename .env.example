# VaultAI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required ────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Optional ────────────────────────────────────────────────────
# HaveIBeenPwned API key (for email breach checking — paid tier)
HIBP_API_KEY=

# Custom database path (default: vault.db in project root)
DB_PATH=vault.db

# Log file path (default: audit.log)
LOG_FILE=audit.log

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
